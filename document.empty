<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pritha S | Future Software Developer</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
* { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
:root {
  --bg: #04071a;
  --surface: rgba(20, 30, 55, 0.42);
  --surface-strong: rgba(22, 31, 62, 0.72);
  --text: #e7e9ff;
  --muted: #a0acec;
  --accent: #6f6aff;
  --accent-light: #3be0ff;
  --shadow: 0 20px 40px rgba(1, 2, 22, 0.7);
  --radius: 18px;
  --transition: 0.35s ease;
}
body {
  font-family: 'Inter', 'Poppins', sans-serif;
  background: radial-gradient(circle at 15% 10%, #1c1d4c 0%, #060719 30%, #02010f 100%);
  min-height: 100vh;
  color: var(--text);
  overflow-x: hidden;
}
.background-pattern {
  position: fixed;
  inset: 0;
  background-image: radial-gradient(circle at 20% 20%, rgba(80, 120, 255,0.18) 0%, transparent 40%), radial-gradient(circle at 80% 14%, rgba(120, 60, 220,0.08) 0%, transparent 40%), linear-gradient(135deg, rgba(20, 36, 91, 0.78), rgba(2,12,36,0.80));
  pointer-events: none;
  z-index: -2;
}
.background-pattern::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: repeating-linear-gradient(45deg, rgba(255,255,255,0.02) 0 1px, transparent 1px 15px);
  opacity: 0.18;
}
.container { width: min(1100px, 92vw); margin: 0 auto; }
.header { position: sticky; top:0; z-index:999; backdrop-filter: blur(10px); background: linear-gradient(90deg, rgba(4,7,21,0.85), rgba(8,10,28,0.65)); border-bottom: 1px solid rgba(142,165,255,0.2); }
.navbar { display:flex; justify-content:space-between; align-items:center; padding: 0.8rem 0; }
.logo { font-size:1.35rem; font-weight:800; letter-spacing:1px; color:#fff; }
.nav-menu { display:flex; gap:1rem; list-style:none; }
.nav-link { color: var(--muted); text-decoration:none; padding:0.5rem 0.6rem; border-radius:10px; transition: var(--transition); font-weight:500; }
.nav-link:hover, .nav-link.active { color:#e8ecff; background:rgba(100,110,255,0.2); box-shadow:0 4px 18px rgba(105,120,255,0.3); }
.mobile-toggle { display:none; width:34px; height:30px; border:none; background:transparent; flex-direction:column; justify-content:space-between; cursor:pointer; }
.mobile-toggle span { display:block; width:100%; height:3px; background-color:var(--text); border-radius:5px; }
.section { padding:80px 0; }
.hero { min-height:calc(100vh-80px); display:grid; place-items:center; }
.hero-inner { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:2rem; align-items:center; }
.hero-content h1 { font-size:clamp(2rem,6vw,4rem); font-weight:800; margin-bottom:0.4rem; text-shadow:0 10px 25px rgba(72,105,255,0.55); }
.tagline { font-size:1.25rem; color:#bbc4ff; margin-bottom:0.75rem; }
.hero-text { color:#c0c8ee; max-width:640px; margin-bottom:1rem; }
.typing { font-weight:600; color:#9acbff; margin-bottom:1.2rem; font-size:1.05rem; }
.cursor { display:inline-block; animation:blink 1s infinite; }
@keyframes blink { 0%,49%{opacity:1;} 50%,100%{opacity:0;} }
.hero-actions { display:flex; gap:0.8rem; margin-bottom:1rem; }
.btn { background:linear-gradient(135deg,#5a72ff 0%,#00e1ff 100%); color:#fff; padding:0.7rem 1.2rem; border-radius:999px; border:none; text-decoration:none; font-weight:600; transition:transform 0.25s ease, box-shadow 0.2s ease; }
.btn:hover { transform:translateY(-2px); box-shadow:0 14px 35px rgba(4,139,255,0.38); }
.btn-outline { background:transparent; border:1px solid rgba(102,214,255,0.85); }
.social-links { display:flex; gap:0.75rem; margin-top:0.5rem; }
.social-links a { inline-flex; width:42px; height:42px; align-items:center; justify-content:center; border-radius:16px; color:#fff; background:rgba(45,64,119,0.48); text-decoration:none; transition:0.35s; }
.social-links a:hover { background:rgba(47,149,255,0.45); transform:translateY(-3px); }
.hero-image { display:grid; place-items:center; }
.glow-card { position:relative; width:min(280px,80vw); height:min(280px,80vw); border-radius:30px; background:linear-gradient(145deg,rgba(47,53,121,0.56),rgba(8,17,52,0.78)); border:1px solid rgba(163,181,255,0.35); box-shadow:0 16px 50px rgba(50,100,255,0.25); overflow:hidden; backdrop-filter:blur(8px); }
.glow-card::before, .glow-card::after { content:''; position:absolute; border-radius:50%; filter:blur(40px); }
.glow-card::before { width:230px; height:230px; background:rgba(113,138,255,0.35); top:-30px; left:-10px; }
.glow-card::after { width:230px; height:230px; background:rgba(0,224,255,0.24); bottom:-40px; right:-20px; }
.circle { position:absolute; border:2px dashed rgba(160,200,255,0.45); border-radius:50%; }
.circle:nth-child(1){ width:180px; height:180px; top:10%; left:10%; }
.circle:nth-child(2){ width:120px; height:120px; bottom:15%; right:14%; }
.circle:nth-child(3){ width:80px; height:80px; top:25%; right:22%; }
.avatar-text { position:absolute; inset:0; display:grid; place-items:center; color:#d4e6ff; font-size:1.1rem; font-weight:700; letter-spacing:2px; text-shadow:0 0 20px rgba(38,149,255,0.7); }
.section-grid { display:grid; gap:1.2rem; }
.section-grid h2 { font-size:clamp(1.75rem,3vw,2.3rem); text-align:center; }
.section-grid p { color:#bbcbf3; line-height:1.7; }
.card { background:var(--surface); border:1px solid rgba(148,170,255,0.2); box-shadow:var(--shadow); border-radius:var(--radius); padding:1rem; }
.experience-card { grid-template-columns:1fr; }
.skills-grid, .projects-grid, .contact-grid { display:grid; gap:1rem; }
.skills-grid { grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); }
.skill-card, .project-card, .contact-card { background:rgba(16,24,48,0.65); padding:1rem; border-radius:18px; border:1px solid rgba(148,170,255,0.2); box-shadow:0 14px 30px rgba(14,26,64,0.45); }
.skill-card h3, .project-card h3, .contact-card h3 { color:#e2ecff; margin-bottom:0.7rem; }
.progress { background:rgba(124,146,200,0.2); border-radius:999px; height:10px; overflow:hidden; margin-bottom:0.9rem; }
.progress span { display:block; height:100%; border-radius:999px; width:var(--value); background:linear-gradient(90deg,#7c8eff,#00e6ff); transition:width 1s ease; }
.project-card { transition:transform 0.35s ease, box-shadow 0.35s ease; }
.project-card:hover { transform:translateY(-6px) scale(1.01); box-shadow:0 20px 45px rgba(40,101,241,0.38); }
.contact-grid { grid-template-columns:repeat(auto-fit,minmax(210px,1fr)); }
.footer { text-align:center; padding:1rem 0; border-top:1px solid rgba(134,156,255,0.25); margin-top:1rem; color:#9caded; background:rgba(4,7,21,0.45); }
.reveal { opacity:0; transform:translateY(22px); transition:all 0.7s ease; }
.reveal.active { opacity:1; transform:translateY(0); }
@media (max-width:900px) { .hero-inner{grid-template-columns:1fr;} .section{padding:60px 0;} }
@media (max-width:768px) { .nav-menu{position:fixed; inset:72px 0 auto 0; background:rgba(6,9,25,0.95); flex-direction:column; padding:1rem 0; gap:0.4rem; backdrop-filter:blur(8px); opacity:0; transform:translateY(-8px); pointer-events:none; transition:0.25s ease; } .nav-menu.visible{opacity:1; transform:translateY(0); pointer-events:auto;} .nav-link{width:100%; text-align:center; padding:0.8rem 0;} .mobile-toggle{display:flex;} }
@media (max-width:480px) { .hero h1 { font-size:2.3rem; } .hero-text { font-size:0.95rem; } .skills-grid, .projects-grid { grid-template-columns:1fr; } }
  </style>
</head>
<body>
  <div class="background-pattern"></div>
  <header class="header" id="header">
    <nav class="navbar container" id="navbar">
      <a href="#hero" class="logo">Pritha S</a>
      <ul class="nav-menu" id="nav-menu">
        <li><a class="nav-link active" href="#hero">Home</a></li>
        <li><a class="nav-link" href="#about">About</a></li>
        <li><a class="nav-link" href="#education">Education</a></li>
        <li><a class="nav-link" href="#skills">Skills</a></li>
        <li><a class="nav-link" href="#experience">Experience</a></li>
        <li><a class="nav-link" href="#projects">Projects</a></li>
        <li><a class="nav-link" href="#certifications">Certifications</a></li>
        <li><a class="nav-link" href="#contact">Contact</a></li>
      </ul>
      <button class="mobile-toggle" id="mobile-toggle" aria-label="Toggle menu"><span></span><span></span><span></span></button>
    </nav>
  </header>
  <main>
    <section class="hero section" id="hero">
      <div class="container hero-inner">
        <div class="hero-content reveal">
          <h1>Pritha S</h1>
          <p class="tagline">Future Software Developer | Problem Solving and Logical Building</p>
          <p class="hero-text">Focused engineering student with strong programming skills in Python and Java, passionate about building real-world applications and solving problems efficiently.</p>
          <p class="typing">I'm currently <span id="typing-text"></span><span class="cursor">|</span></p>
          <div class="hero-actions"><a href="mailto:prithasakthivel07@gmail.com" class="btn">Email Me</a><a href="#contact" class="btn btn-outline">Contact</a></div>
          <div class="social-links"><a href="mailto:prithasakthivel07@gmail.com" aria-label="Email"></a><a href="tel:8667270234" aria-label="Phone"></a></div>
        </div>
        <div class="hero-image reveal">
          <div class="glow-card"><div class="circle"></div><div class="circle"></div><div class="circle"></div><div class="avatar-text">AI + CSE</div></div>
        </div>
      </div>
    </section>
    <section class="section" id="about">
      <div class="container section-grid reveal"><h2>About Me</h2><p>I am a Computer Science Engineering student specializing in Artificial Intelligence and Machine Learning. I enjoy transforming ideas into practical solutions and continuously improving my technical and problem-solving skills.</p></div>
    </section>
    <section class="section" id="education">
      <div class="container section-grid reveal"><h2>Education</h2><div class="card"><h3>BE CSE (AI & ML)</h3><p>K S Rangasamy College of Technology, Namakkal (2024–2028)</p><p><strong>CGPA:</strong> 8.89</p></div><div class="card"><h3>HSC</h3><p>Avvai Matric Higher Secondary School, Dharmapuri</p><p><strong>Percentage:</strong> 82.5%</p></div><div class="card"><h3>SSLC</h3><p>Avvai Matric Higher Secondary School, Dharmapuri</p><p><strong>Percentage:</strong> 89.4%</p></div></div>
    </section>
    <section class="section" id="skills">
      <div class="container section-grid reveal"><h2>Skills</h2><div class="skills-grid"><div class="skill-card"><h3>Programming</h3><p>Python</p><div class="progress"><span style="--value: 90%"></span></div><p>Java</p><div class="progress"><span style="--value: 85%"></span></div></div><div class="skill-card"><h3>Web Development</h3><p>HTML</p><div class="progress"><span style="--value: 90%"></span></div><p>CSS</p><div class="progress"><span style="--value: 87%"></span></div><p>JavaScript</p><div class="progress"><span style="--value: 80%"></span></div></div><div class="skill-card"><h3>Frameworks & Tools</h3><p>ReactJS</p><div class="progress"><span style="--value: 78%"></span></div><p>GitHub</p><div class="progress"><span style="--value: 88%"></span></div><p>LeetCode</p><div class="progress"><span style="--value: 84%"></span></div></div></div></div>
    </section>
    <section class="section" id="experience">
      <div class="container section-grid reveal"><h2>Experience</h2><div class="card experience-card"><h3>AICTE Internship</h3><p><strong>Role:</strong> Python Full Stack Developer Intern</p><p>Worked on scalable AI-inspired applications with modern Python tooling and full stack practices.</p></div></div>
    </section>
    <section class="section" id="projects">
      <div class="container section-grid reveal"><h2>Projects</h2><div class="projects-grid"><article class="project-card"><h3>Blood Pressure Analysis</h3><p>Python Tkinter</p><p>Developed a system to analyze and categorize blood pressure levels including normal, elevated, and hypertension stages with real-time feedback.</p></article><article class="project-card"><h3>Portfolio Web Experience</h3><p>Modern UI, responsive interactions, glassmorphism and typed effects</p></article></div></div>
    </section>
    <section class="section" id="certifications">
      <div class="container section-grid reveal"><h2>Certifications</h2><div class="card"><h3>Oracle – Generative AI</h3><p>Certification in Generative AI concepts and application best practices.</p></div></div>
    </section>
    <section class="section" id="contact">
      <div class="container section-grid reveal"><h2>Contact</h2><div class="contact-grid"><div class="contact-card"><h3>Email</h3><p><a href="mailto:prithasakthivel07@gmail.com">prithasakthivel07@gmail.com</a></p></div><div class="contact-card"><h3>Phone</h3><p><a href="tel:8667270234">8667270234</a></p></div><div class="contact-card"><h3>Location</h3><p>Dharmapuri, Tamil Nadu</p></div></div></div>
    </section>
  </main>
  <footer class="footer"><p>&copy; <span id="year"></span> Pritha S. All rights reserved.</p></footer>
  <script>
document.addEventListener('DOMContentLoaded', () => {
  const typedText = document.getElementById('typing-text');
  const words = ['learning AI models.', 'building software solutions.', 'solving complex problems.', 'growing in full stack development.'];
  let wordIndex = 0;
  let charIndex = 0;
  let forward = true;
  function type() {
    const current = words[wordIndex];
    if (forward) {
      typedText.textContent = current.slice(0, charIndex + 1);
      charIndex++;
      if (charIndex === current.length) {
        forward = false;
        setTimeout(type, 1300);
        return;
      }
    } else {
      typedText.textContent = current.slice(0, charIndex - 1);
      charIndex--;
      if (charIndex === 0) {
        forward = true;
        wordIndex = (wordIndex + 1) % words.length;
      }
    }
    setTimeout(type, forward ? 100 : 50);
  }
  type();
  const sections = document.querySelectorAll('section');
  const revealElements = document.querySelectorAll('.reveal');
  const navLinks = document.querySelectorAll('.nav-link');
  function revealOnScroll() {
    const triggerBottom = window.innerHeight / 1.1;
    revealElements.forEach(item => {
      const itemTop = item.getBoundingClientRect().top;
      if (itemTop < triggerBottom) {
        item.classList.add('active');
      }
    });
  }
  window.addEventListener('scroll', revealOnScroll);
  revealOnScroll();
  function setActiveNav() {
    let currentId = '';
    sections.forEach(section => {
      const sectionTop = section.offsetTop - 125;
      if (window.scrollY >= sectionTop) {
        currentId = section.getAttribute('id');
      }
    });
    navLinks.forEach(link => {
      link.classList.toggle('active', link.getAttribute('href') === `#${currentId}`);
    });
  }
  window.addEventListener('scroll', setActiveNav);
  setActiveNav();
  document.getElementById('mobile-toggle').addEventListener('click', () => {
    document.getElementById('nav-menu').classList.toggle('visible');
  });
  navLinks.forEach(link => {
    link.addEventListener('click', e => {
      if (link.hash !== '') {
        e.preventDefault();
        document.querySelector(link.hash).scrollIntoView({ behavior: 'smooth', block: 'start' });
        if (window.innerWidth < 768) {
          document.getElementById('nav-menu').classList.remove('visible');
        }
      }
    });
  });
  document.getElementById('year').textContent = new Date().getFullYear();
});
  </script>
</body>
</html>
